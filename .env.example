# MedRelay — Environment Variables
# Copy this file to .env and fill in your real API keys before running.

# OpenAI API key — used for Whisper transcription (Agent 1 — Relay)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API key — used for Claude SBAR extraction + report generation (Agents 2 & 4)
ANTHROPIC_API_KEY=https://api.anthropic.com/v1/complete
